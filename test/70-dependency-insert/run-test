#! /bin/sh

[ "${TRACE}" = 'YES' ] && set -x && : "$0" "$@"

###   ###   ###   ###   ###   ###   ###   ###   ###   ###   ###   ###   ###
MULLE_BASHFUNCTIONS_LIBEXEC_DIR="`mulle-bashfunctions libexec-dir`" || exit 1
export MULLE_BASHFUNCTIONS_LIBEXEC_DIR
. "${MULLE_BASHFUNCTIONS_LIBEXEC_DIR}/mulle-boot.sh" || exit 1
. "${MULLE_BASHFUNCTIONS_LIBEXEC_DIR}/mulle-bashfunctions.sh" || exit 1
###   ###   ###   ###   ###   ###   ###   ###   ###   ###   ###   ###   ###


run_mulle_sde()
{
   log_fluff "####################################" >&2
   log_fluff ${MULLE_SDE} ${MULLE_SDE_FLAGS} "$@"
   log_fluff "####################################" >&2

   (
      MULLE_EXECUTABLE="${MULLE_SDE}"
      MULLE_SDE_LIBEXEC_DIR="`${MULLE_SDE} libexec-dir`"

      . "${MULLE_SDE}" ${MULLE_SDE_FLAGS} "$@"
   )
}


main()
{
   MULLE_SDE_FLAGS="$@"

   _options_mini_main "$@" && set -x

   MULLE_SDE_EXTENSION_PATH="${PWD}"
   export MULLE_SDE_EXTENSION_PATH

   local directory

   r_make_tmp_directory || exit 1
   directory="${RVAL}"
   directory="${directory:-/tmp/build}"

   #
   # Init a minimal project
   #
   log_verbose "Init project"

   run_mulle_sde -s init --no-post-init \
                    -d "${directory}" \
                    --project-name "TestProject" \
                    --style mulle/wild \
                    none \
   || fail "init failed"

   [ ! -d "${directory}/.mulle" ] && fail "init failed: no .mulle directory"

   #
   # Add two dependencies so the sourcetree has some content
   #
   log_verbose "Add alpha and beta as no-fetch file dependencies"

   (
      cd "${directory}" &&
      run_mulle_sde -s dependency add \
                        --nodetype file \
                        --address alpha \
                        alpha
   ) || fail "dependency add alpha failed"

   (
      cd "${directory}" &&
      run_mulle_sde -s dependency add \
                        --nodetype file \
                        --address beta \
                        beta
   ) || fail "dependency add beta failed"

   #
   # Verify order: alpha should be first, beta second
   #
   local order

   order="`( cd "${directory}" && run_mulle_sde -s dependency list -- --output-format raw --output-no-header ) 2>/dev/null \
           | sed 's/;.*//'`"
   log_verbose "Order after two adds: ${order}"

   case "${order}" in
      alpha*beta*) ;;
      *) fail "#1 expected alpha before beta, got: ${order}" ;;
   esac
   log_verbose "----- #1 PASSED (alpha before beta after two adds) -----"

   #
   # Now insert gamma - it should end up at the top
   #
   log_verbose "Insert gamma - should land at top"

   (
      cd "${directory}" &&
      run_mulle_sde -s dependency insert \
                        --nodetype file \
                        --address gamma \
                        gamma
   ) || fail "dependency insert gamma failed"

   order="`( cd "${directory}" && run_mulle_sde -s dependency list -- --output-format raw --output-no-header ) 2>/dev/null \
           | sed 's/;.*//'`"
   log_verbose "Order after insert: ${order}"

   case "${order}" in
      gamma*alpha*beta*) ;;
      *) fail "#2 expected gamma at top (gamma,alpha,beta), got: ${order}" ;;
   esac
   log_verbose "----- #2 PASSED (inserted dependency is at top) -----"

   #
   # Insert a second time - delta should also land at top, pushing gamma down
   #
   log_verbose "Insert delta - should also land at top"

   (
      cd "${directory}" &&
      run_mulle_sde -s dependency insert \
                        --nodetype file \
                        --address delta \
                        delta
   ) || fail "dependency insert delta failed"

   order="`( cd "${directory}" && run_mulle_sde -s dependency list -- --output-format raw --output-no-header ) 2>/dev/null \
           | sed 's/;.*//'`"
   log_verbose "Order after second insert: ${order}"

   case "${order}" in
      delta*gamma*alpha*beta*) ;;
      *) fail "#3 expected delta at top (delta,gamma,alpha,beta), got: ${order}" ;;
   esac
   log_verbose "----- #3 PASSED (second inserted dependency is at top) -----"

   log_info "----- ALL PASSED -----"
   cd /
   chmod -R u+w "${directory}" 2>/dev/null
   rmdir_safer "${directory}"
}


init()
{
   MULLE_SDE="${MULLE_SDE:-${PWD}/../../mulle-sde}"
}


init "$@"
main "$@"
